local TPLayout = Instance.new("UIListLayout", TPScroll); TPLayout.Padding = UDim.new(0, 2)

local function updateTPList()
    for _, v in pairs(TPScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local pBtn = createBtn(p.DisplayName, Color3.fromRGB(40, 40, 40), TPScroll)
            pBtn.Size = UDim2.new(1, 0, 0, 30); pBtn.MouseButton1Click:Connect(function()
                if p.Character and player.Character then player.Character:MoveTo(p.Character.HumanoidRootPart.Position) end
            end)
        end
    end
end
Players.PlayerAdded:Connect(updateTPList); Players.PlayerRemoving:Connect(updateTPList); updateTPList()

