-- --- BOUCLE RENDU ---
local renderConn = RunService.RenderStepped:Connect(function()
    if not active then return end
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
        char.Humanoid.WalkSpeed = walkSpeed
        if godMode then char.Humanoid.Health = 100 end
        for _, v in pairs(char:GetChildren()) do if v:IsA("BasePart") then v.Transparency = invisible and 1 or (v.Name == "HumanoidRootPart" and 1 or 0) end end
        
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local tHrp = p.Character:FindFirstChild("HumanoidRootPart")
                local head = p.Character:FindFirstChild("Head")
                if tHrp and head then
                    if espActive then
                        if not p.Character:FindFirstChild("ESPH") then
                            Instance.new("Highlight", p.Character).Name = "ESPH"
                            local b = Instance.new("BillboardGui", head); b.Name = "ESPT"; b.AlwaysOnTop = true; b.Size = UDim2.new(0,80,0,20); b.ExtentsOffset = Vector3.new(0,3,0)
                            local l = Instance.new("TextLabel", b); l.Text = p.DisplayName; l.Size = UDim2.new(1,0,1,0); l.BackgroundTransparency = 1; l.TextColor3 = Color3.new(1,1,1); l.Font = "SourceSansBold"; l.TextSize = 10
                            local a0 = Instance.new("Attachment", char.HumanoidRootPart); a0.Name = "A0_"..p.Name
                            local a1 = Instance.new("Attachment", tHrp); a1.Name = "A1_"..p.Name
                            local beam = Instance.new("Beam", char.HumanoidRootPart); beam.Name = "T_"..p.Name; beam.Color = ColorSequence.new(Color3.new(1,0,0)); beam.Width0 = 0.1; beam.Attachment0 = a0; beam.Attachment1 = a1; beam.FaceCamera = true
                        end
                    else
                        if p.Character:FindFirstChild("ESPH") then p.Character.ESPH:Destroy() end
                        if head:FindFirstChild("ESPT") then head.ESPT:Destroy() end
                        if char.HumanoidRootPart:FindFirstChild("T_"..p.Name) then char.HumanoidRootPart["T_"..p.Name]:Destroy(); char.HumanoidRootPart["A0_"..p.Name]:Destroy() end
                    end
                    if hbActive and not tHrp:IsDescendantOf(char) then
                        tHrp.Size = Vector3.new(hbSize, hbSize, hbSize); tHrp.Transparency = 0.5; tHrp.Color = Color3.new(1,0,0); tHrp.CanCollide = false
                    else
                        tHrp.Size = Vector3.new(2,2,1); tHrp.Transparency = 1
                    end
                end
            end
        end
    end
end)

